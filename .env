VISION_AI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

JIRA_BASE_URL=https://jira.digital.ingka.com
JIRA_JQL=assignee=currentUser() AND statusCategory != Done ORDER BY updated DESC
JIRA_PAGE_SIZE=50
JIRA_DATA_DIR=data/jira
JIRA_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
JIRA_EMBEDDING_BATCH_SIZE=32
JIRA_REQUEST_TIMEOUT_SECONDS=30
JIRA_MAX_RETRIES=3

# Optional LLM provider settings.
JIRA_LLM_PROVIDER=extractive
JIRA_LLM_MODEL=gpt-4o-mini
JIRA_LLM_BASE_URL=https://api.openai.com/v1
JIRA_LLM_API_KEY=
